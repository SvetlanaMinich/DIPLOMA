# Application
APP_NAME=AutoSTP
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://autostp:autostp_password@localhost:5432/autostp_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — в продакшене замените на реальный домен фронтенда
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_SEGMENT=10/minute

# OpenRouter API (https://openrouter.ai/docs)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_MAX_RETRIES=4
OPENROUTER_RETRY_BASE_SECONDS=1.0
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=AutoSTP

# File storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=30

# Auto-save
AUTO_SAVE_INTERVAL_SECONDS=300

# Pricing (BYN)
PRICING_DOCUMENT_SMALL_PAGES=40
PRICING_DOCUMENT_SMALL_PRICE=7.0
PRICING_DOCUMENT_LARGE_PRICE=15.0
PRICING_TEMPLATE_PRICE=10.0
